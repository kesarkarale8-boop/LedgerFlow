generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  companies Company[]
}

model Company {
  id                 String    @id @default(cuid())
  userId             String
  name               String
  address            String?
  gstNumber          String?
  state              String?
  phone              String?
  email              String?
  financialYearStart DateTime?
  financialYearEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  ledgers    Ledger[]
  customers  Customer[]
  suppliers  Supplier[]
  stockItems StockItem[]
  vouchers   Voucher[]
}

model Ledger {
  id                 String   @id @default(cuid())
  companyId          String
  name               String
  ledgerType         String
  openingBalance     Decimal  @default(0)
  openingBalanceType String?
  gstin              String?
  mobile             String?
  email              String?
  address            String?
  state              String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  mobile    String?
  email     String?
  address   String?
  gstin     String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Supplier {
  id        String   @id @default(cuid())
  companyId String
  name      String
  mobile    String?
  email     String?
  address   String?
  gstin     String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model StockItem {
  id               String   @id @default(cuid())
  companyId        String
  name             String
  sku              String?
  hsnCode          String?
  purchasePrice    Decimal  @default(0)
  sellingPrice     Decimal  @default(0)
  gstRate          Decimal  @default(0)
  openingStockQty  Decimal  @default(0)
  currentStock     Decimal  @default(0)
  minStock         Decimal  @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Voucher {
  id            String   @id @default(cuid())
  companyId     String
  voucherType   String
  voucherNumber String
  date          DateTime
  notes         String?
  subtotal      Decimal  @default(0)
  cgst          Decimal  @default(0)
  sgst          Decimal  @default(0)
  igst          Decimal  @default(0)
  discount      Decimal  @default(0)
  roundOff      Decimal  @default(0)
  total         Decimal  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
